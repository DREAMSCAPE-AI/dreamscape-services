# DREAMSCAPE AI Service - Environment Variables
# Copy this file to .env for local development only

# =============================================================================
# DATABASE CONNECTION
# =============================================================================
# NOTE: In Docker/production, DATABASE_URL is automatically set by docker-compose
# from the shared @dreamscape/db PostgreSQL service.
# Only set this manually for local development outside Docker.
#
# DATABASE_URL=postgresql://postgres:password123@localhost:5432/dreamscape

# =============================================================================
# ML ETL CONFIGURATION
# =============================================================================
DATASET_VERSION=1.0
DATA_WINDOW_DAYS=90
NEGATIVE_SAMPLE_RATIO=2.0
TEST_SIZE=0.2
RANDOM_SEED=42

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/etl.log

# =============================================================================
# DATA DIRECTORIES (automatically created by pipeline)
# =============================================================================
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
DATASETS_DIR=./data/datasets
